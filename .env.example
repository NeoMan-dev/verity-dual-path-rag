# Copy this file to .env and fill in your credentials.
# .env is gitignored — your keys will NOT be committed to GitHub.

# Optional: API key to protect your RAG server endpoints (default: dev-secret-key)
RAG_API_KEY=your-rag-api-key-here

# Optional: Set these here if you prefer env vars over entering them in the UI
GROQ_API_KEY=your-groq-api-key-here
HF_TOKEN=your-huggingface-token-here

# Optional: Override the embedding model (default: sentence-transformers/all-MiniLM-L6-v2)
# EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
